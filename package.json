{
  "name": "@tangvu/airules",
  "version": "0.4.0",
  "description": "One config to rule them all. Generate & sync AI coding rules across every tool.",
  "type": "module",
  "bin": {
    "airules": "./dist/index.js"
  },
  "files": ["dist", "templates", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tang-vu/airules.git"
  },
  "keywords": ["ai", "coding-rules", "claude", "cursor", "copilot", "cli", "developer-tools"],
  "author": "Tang Vu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tang-vu/airules/issues"
  },
  "homepage": "https://github.com/tang-vu/airules#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ora": "^8.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
